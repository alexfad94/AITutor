BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/onboarding
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_BASE_URL=https://api.openai.com/v1
TRAINING_TOPIC=Основы кибербезопасности
TRAINING_MATERIAL=Пароли должны быть длинными (от 12 символов), уникальными для каждого сервиса и храниться в менеджере паролей; использование одного пароля на нескольких сайтах запрещено. Многофакторная аутентификация (MFA) обязательна для корпоративной почты, VPN и критичных систем — второй фактор не передают коллегам и не отключают «для удобства». Фишинг распознают по срочности, необычному отправителю, подозрительным ссылкам и запросам пароля или кодов; подозрительные письма не открывают и сообщают в ИБ. Рабочие данные не отправляют в личную почту и мессенджеры, а на съёмные носители — только с разрешения и шифрованием. Обновления ОС и ПО устанавливают вовремя: известные уязвимости часто закрываются патчами. Публичный Wi‑Fi для доступа к корпоративным системам используют только через VPN; без VPN не вводят рабочие пароли и не открывают конфиденциальные документы. При утере устройства, подозрении на взлом или случайной утечке данных сотрудник сразу сообщает в службу информационной безопасности и не пытается «разобраться сам» скрытно.
QUIZ_QUESTION_COUNT=5
LOG_LEVEL=INFO
